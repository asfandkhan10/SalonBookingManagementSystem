@model List<ServiceViewModel>
@{
    ViewData["Title"] = "Manage Services";
    Layout = "_AdminLayout";
}

<h2>Manage Services</h2>

<div class="mb-3">
    <a asp-action="CreateService" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add Service
    </a>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Duration</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Name</td>
                        <td>@s.Description</td>
                        <td>$@s.Price.ToString("0.00")</td>
                        <td>@s.DurationMinutes min</td>
                        <td>
                            <form method="post" asp-action="DeleteService" asp-route-id="@s.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this service?')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No services found. <a asp-action="CreateService">Add one now</a>
    </div>
}
